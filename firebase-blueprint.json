{
  "entities": {
    "Config": {
      "title": "LinkFlow Configuration",
      "description": "The configuration settings of LinkFlow WhatsApp re-router including groups, delays, logs, and state settings",
      "type": "object",
      "properties": {
        "includeSenderPrefix": {
          "type": "boolean",
          "description": "Whether to include the sender name prefix"
        },
        "forwardDelayMs": {
          "type": "integer",
          "description": "Delay in milliseconds between forwards"
        },
        "cloudPersistenceEnabled": {
          "type": "boolean",
          "description": "Whether cloud database sync is enabled"
        },
        "masterGroup": {
          "type": "object",
          "description": "Master WhatsApp group to forward from"
        },
        "targetGroups": {
          "type": "array",
          "description": "Target WhatsApp groups to re-route to"
        },
        "logs": {
          "type": "array",
          "description": "Logs of forwarded messages"
        }
      }
    },
    "WhatsAppSession": {
      "title": "WhatsApp Session Data",
      "description": "Persistent Baileys authentication state data",
      "type": "object",
      "properties": {
        "data": {
          "type": "object",
          "description": "Serialized authentication state data"
        }
      }
    }
  },
  "firestore": {
    "configs/main": {
      "schema": "Config",
      "description": "Global LinkFlow persistence document"
    },
    "sessions/{sessionId}": {
      "schema": "WhatsAppSession",
      "description": "Persistent Baileys sessions"
    }
  }
}
